# Embedding provider: qwen or doubao
EMBEDDING_PROVIDER=qwen

# Embedding model name used by the selected provider
EMBEDDING_MODEL=text-embedding-v3

# Embedding vector dimension, for example 1024 or 2048
EMBEDDING_DIM=1024

# Enable multimodal embedding for images / videos when the model supports it
EMBEDDING_MULTIMODAL_ENABLED=false

# Embedding API Key / Base URL
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM provider / model / credentials
LLM_PROVIDER=qwen
LLM_MODEL=qwen-max
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Markdown notes directory mounted by Lazycat
NOTES_DIR=/lzcapp/var/notes

# Asset directory for local images
ASSETS_DIR=/lzcapp/var/assets

# SQLite database file path
DB_PATH=/lzcapp/var/data/index.db
